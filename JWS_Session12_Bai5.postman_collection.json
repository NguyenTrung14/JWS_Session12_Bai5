{
  "info": {
    "name": "JWS Session12 Bai5 - Product API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Get all products",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products"
      }
    },
    {
      "name": "Create product",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productCode\": \"P001\",\n  \"productName\": \"Laptop Dell XPS 13\",\n  \"description\": \"Ultrabook for office and study\",\n  \"price\": 32990000,\n  \"quantity\": 10\n}"
        },
        "url": "{{baseUrl}}/api/products"
      }
    },
    {
      "name": "Get product by id",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products/1"
      }
    },
    {
      "name": "Update product",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productCode\": \"P001\",\n  \"productName\": \"Laptop Dell XPS 13 Plus\",\n  \"description\": \"Updated ultrabook model\",\n  \"price\": 35990000,\n  \"quantity\": 7\n}"
        },
        "url": "{{baseUrl}}/api/products/1"
      }
    },
    {
      "name": "Delete product",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/products/1"
      }
    },
    {
      "name": "Get missing product - 404",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products/999"
      }
    },
    {
      "name": "Update missing product - 404",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productCode\": \"P999\",\n  \"productName\": \"Missing Product\",\n  \"description\": \"Not found update case\",\n  \"price\": 100000,\n  \"quantity\": 1\n}"
        },
        "url": "{{baseUrl}}/api/products/999"
      }
    },
    {
      "name": "Delete missing product - 404",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/products/999"
      }
    }
  ]
}
